<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PKHeX.Presentation.ViewModels;assembly=PKHeX.Presentation"
             xmlns:loc="using:PKHeX.Avalonia.Localization"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
             x:Class="PKHeX.Avalonia.Views.BoxExporter"
             x:DataType="vm:BoxExporterViewModel">

    <Grid RowDefinitions="Auto, *, Auto" Margin="10">
        <StackPanel Grid.Row="0" Spacing="10">
            <TextBlock Text="{loc:Loc BoxExporter_Title}" FontSize="18" FontWeight="Bold"/>

            <TextBlock Text="{loc:Loc BoxExporter_FileNamerLabel}"/>
            <ComboBox ItemsSource="{Binding NamerList}" SelectedItem="{Binding SelectedNamer}" HorizontalAlignment="Stretch"/>

            <!-- Additional settings could go here -->
            <!-- e.g. CheckBox for 'Modify dates', etc. -->
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Content="{loc:Loc Common_Cancel}" Command="{Binding CloseRequested}"/>
            <Button Content="{loc:Loc BoxExporter_ExportButton}" Command="{Binding ExportCommand}" Classes="accent"/>
        </StackPanel>
    </Grid>
</UserControl>
