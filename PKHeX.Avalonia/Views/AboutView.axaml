<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PKHeX.Presentation.ViewModels;assembly=PKHeX.Presentation"
             xmlns:loc="using:PKHeX.Avalonia.Localization"
             x:Class="PKHeX.Avalonia.Views.AboutView"
             x:DataType="vm:AboutViewModel"
             Width="400" Height="250">
    <Border Padding="24" Classes="view-container">
        <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{loc:Loc About_Brand}"
                       FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{loc:Loc About_Edition}"
                       FontSize="16"
                       Opacity="0.7"
                       HorizontalAlignment="Center" />
            
            <Separator />
            
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding UIVersion, StringFormat='PKHeX Avalonia v{0}'}"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding CoreVersion, StringFormat='Core: {0}'}"
                           HorizontalAlignment="Center"
                           FontSize="12" />
                <TextBlock Text="{Binding AvaloniaVersion, StringFormat='Avalonia UI: {0}'}"
                           HorizontalAlignment="Center"
                           FontSize="12" />
            </StackPanel>

            <TextBlock Text="{loc:Loc About_UIPort}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0" />
            <TextBlock Text="{loc:Loc About_CoreCredit}"
                       FontSize="11"
                       Opacity="0.8"
                       HorizontalAlignment="Center" />
            
            <Button Content="{loc:Loc Common_Close}"
                    Click="OnCloseClick"
                    HorizontalAlignment="Center"
                    Classes="accent"
                    Margin="0,8,0,0" />
        </StackPanel>
    </Border>
</UserControl>
