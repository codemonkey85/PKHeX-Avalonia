<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PKHeX.Presentation.ViewModels;assembly=PKHeX.Presentation"
             xmlns:loc="using:PKHeX.Avalonia.Localization"
             x:Class="PKHeX.Avalonia.Views.InventoryEditor"
             x:DataType="vm:InventoryEditorViewModel">

    <Border Padding="16" Classes="view-container">
        <DockPanel>
            <!-- Header -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <TextBlock Text="{loc:Loc InventoryEditor_Title}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button Content="{loc:Loc InventoryEditor_Reset}" Command="{Binding ResetCommand}" Padding="12,6" />
                    <Button Content="{loc:Loc InventoryEditor_Apply}" Command="{Binding SaveCommand}" Classes="accent" Padding="12,6" />
                </StackPanel>
            </DockPanel>

            <!-- Pouch Tabs -->
            <TabControl ItemsSource="{Binding Pouches}"
                        SelectedItem="{Binding SelectedPouch}">
                <TabControl.ItemTemplate>
                    <DataTemplate DataType="vm:InventoryPouchViewModel">
                        <TextBlock Text="{Binding PouchName}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate DataType="vm:InventoryPouchViewModel">
                        <DockPanel>
                            <!-- Toolbar -->
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,8,0,12">
                                <Button Content="{loc:Loc InventoryEditor_SortByName}"
                                        Command="{Binding $parent[TabControl].((vm:InventoryEditorViewModel)DataContext).SortByNameCommand}"
                                        Padding="8,4" />
                                <Button Content="{loc:Loc InventoryEditor_SortByCount}"
                                        Command="{Binding $parent[TabControl].((vm:InventoryEditorViewModel)DataContext).SortByCountCommand}"
                                        Padding="8,4" />
                                <Separator />
                                <Button Content="{loc:Loc InventoryEditor_GiveAll}"
                                        Command="{Binding $parent[TabControl].((vm:InventoryEditorViewModel)DataContext).GiveAllCommand}"
                                        Padding="8,4" />
                                <Button Content="{loc:Loc InventoryEditor_ClearAll}"
                                        Command="{Binding $parent[TabControl].((vm:InventoryEditorViewModel)DataContext).ClearAllCommand}"
                                        Padding="8,4" />
                            </StackPanel>

                            <!-- Items List -->
                            <Border Classes="section-card" CornerRadius="4" Padding="0" ClipToBounds="True">
                                <DataGrid ItemsSource="{Binding Items}"
                                          AutoGenerateColumns="False"
                                          CanUserResizeColumns="True"
                                          CanUserSortColumns="False"
                                          MaxHeight="450">
                                    <DataGrid.Columns>
                                        <!-- Icon Column -->
                                        <DataGridTemplateColumn Header="" Width="36">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate DataType="vm:InventoryItemViewModel">
                                                    <Image Width="24" Height="24"
                                                           Source="{Binding Sprite, Converter={StaticResource PngBytesToBitmap}}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Item Column -->
                                        <DataGridTemplateColumn Header="{loc:Loc InventoryEditor_Item}" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate DataType="vm:InventoryItemViewModel">
                                                    <ComboBox ItemsSource="{Binding ItemList}"
                                                              SelectedValue="{Binding ItemId}"
                                                              SelectedValueBinding="{Binding Value}"
                                                              DisplayMemberBinding="{Binding Text}"
                                                              HorizontalAlignment="Stretch"
                                                              AutomationProperties.Name="Item" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        
                                        <!-- Count Column -->
                                        <DataGridTemplateColumn Header="{loc:Loc InventoryEditor_Count}" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate DataType="vm:InventoryItemViewModel">
                                                    <NumericUpDown Value="{Binding Count}"
                                                                   Minimum="0"
                                                                   Maximum="{Binding MaxCount}"
                                                                   FormatString="0"
                                                                   Classes="compact"
                                                                   HorizontalAlignment="Stretch"
                                                                   AutomationProperties.Name="Count" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </DockPanel>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </DockPanel>
    </Border>
</UserControl>
